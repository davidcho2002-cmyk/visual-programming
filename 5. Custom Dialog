# QDialog를 상속받아 사용자 정의 대화상자 class를 정의
class CustomDlg(QDialog):                                                                                        #클래스를 커스텀 다이아로그로 설정 큐다이아로그 가져오기 
    def __init__(self, parent=None):                                                                             #__init__(self)는 부모칸 아예 없애버려서 대체해버리는거고, __init__(self,parent=None)은 부모칸이 존재, 부모가 있는지 없는지는 모르는거 넣을 수 있게끔. 종속이 되어버린다. 
        """ 생성자(Constructor) """
        super().__init__(parent)

        self.setWindowTitle('Hello, QDialog')                                                                   #타이틀바를 헬로 큐다이아로그로 한다 

        # QDialogButtonBox를 사용하여 표준 버튼 (OK, Cancel)을 생성
        buttons = QDialogButtonBox.StandardButton.Ok | QDialogButtonBox.StandardButton.Cancel
        self.button_box = QDialogButtonBox(buttons)
        # button_box의 accepted 시그널을 QDialog의 내장 슬롯인 accept에 연결
        self.button_box.accepted.connect(self.accept)
        # button_box의 rejected 시그널을 QDialog의 내장 슬롯인 reject에 연결
        self.button_box.rejected.connect(self.reject)

        # 대화상자 내부 레이아웃 설정
        self.layout = QVBoxLayout()
        message = QLabel('Is something ok?')
        self.layout.addWidget(message)
        self.layout.addWidget(self.button_box)
        self.setLayout(self.layout)
