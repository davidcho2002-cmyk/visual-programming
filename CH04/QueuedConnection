import sys
import time

from PySide6.QtCore import QThread, Qt, Signal                      #실행시킬 도구들 가져오기 
from PySide6.QtWidgets import (
    QApplication,
    QLabel,
    QPushButton,
    QVBoxLayout,
    QWidget,
)


class Worker(QThread):                                               #일을 하는 별도의 쓰레드 
    """
    별도의 thread에서 작업을 수행하고
    완료 시 Signal을 emit하는 worker.
    """

    work_done = Signal(str)                                          #일이 끝나면 신호를 보내주기         

    def run(self):                                                   #작동시   
        import threading

        tid = threading.current_thread().name                        #일꾼 이름 가져오기            
        print(f"[Worker] run() executing in: {tid}")                 #cmd에 호출   

        # 시간이 걸리는 작업을 simulation.
        time.sleep(1)                                                #현재 쓰레드를 1초동안 멈추기    

        self.work_done.emit(f"Work completed in: {tid}")             #작업 완료된 쓰레드 이름을 출력  괄호 안의 문자를 전달하기   


class MW(QWidget):                                                  #도구가져오기     
    def __init__(self):
        super().__init__()
        self.worker = None                                          #위의 워커를 사용하기 쉽게 하려고 가져오기  처음엔 아무것도 없으니 비활성화 시키기              
        self.init_ui()

    def init_ui(self):                                                      #시작하고요 윈도우 기본 세팅이요
        self.setWindowTitle("QueuedConnection Ex")
        self.resize(420, 180)

        self.label = QLabel(
            "Button을 누르면 worker thread에서 작업 후\n"
            "main thread의 Slot이 비동기로 호출됨."
        )
        self.button = QPushButton("Start Worker")
        self.button.clicked.connect(self.start_worker)

        layout = QVBoxLayout()                                                  #배치 구상 
        layout.addWidget(self.label)
        layout.addWidget(self.button)
        self.setLayout(layout)

    def start_worker(self):                                         #버튼 못누르게 막기 
        self.button.setEnabled(False)
        self.label.setText("Worker thread 실행 중...")              #화면 글자 바꾸기 

        self.worker = Worker()                                      #워커 실행하기 

        # QueuedConnection: Slot이 receiver(main)의
        # Event Loop에서 비동기적으로 실행됨.
        self.worker.work_done.connect(                              #통신규격 정하기 
            self.on_work_done,                                      #무전기         
            Qt.ConnectionType.QueuedConnection,                     #할일 다 끝나면무전만 쳐라 
        )

        self.worker.start()                                         #현장에서 일 하고와     

    def on_work_done(self, message):                                #메시지: 워커 뒤에 나오는 str
        """
        QueuedConnection으로 연결된 Slot.

        Worker thread에서 emit된 Signal이
        main thread의 posted event queue에 등록된 뒤,
        main thread의 Event Loop가 처리할 때 호출됨.
        """

        import threading

        tid = threading.current_thread().name
        print(f"[QueuedConnection] on_work_done() called in: {tid}")
        print(f"[QueuedConnection] message: {message}")

        self.label.setText(
            f"Result: {message}\n"
            f"Slot executed in: {tid}"
        )
        self.button.setEnabled(True)                        #버튼 클릭이 가능하게 바꾸기 


if __name__ == "__main__":                                  #종료 
    app = QApplication(sys.argv)
    window = MW()
    window.show()
    sys.exit(app.exec())
