import sys

try:                                                                  #이거 쓸거고 아닌경우에 경고할거에요 
    from PySide6.QtWidgets import (
        QApplication, QWidget,
        QLabel, QLineEdit, QPushButton,
    )
    qt_modules = 'PySide6'
except ImportError:
    try:
        from PyQt6.QtWidgets import (
            QApplication, QWidget,
            QLabel, QLineEdit, QPushButton,
        )
        qt_modules = 'PyQt6'
    except ImportError:
        print("PySide6 또는 PyQt6가 설치되어 있지 않습니다.")
        sys.exit(1)


class MW(QWidget):                                                                  #기본값 정렬 

    def __init__(self):
        super().__init__()
        self.init_ui()

    def init_ui(self):                                                              #창 사이즈랑 제목 바 정하기 한다음에 메인윈도우라 정의도니 것들 보여줘라 
        self.setFixedSize(340, 120)   # 창 크기 고정
        self.setWindowTitle("QLineEdit Example")
        self.setup_main_wnd()
        self.show()

    def setup_main_wnd(self):                                                        #큐라벨에 "Please enter your name below."적고 위치는 50,10
        QLabel("Please enter your name below.", self).move(50, 10)

        name_label = QLabel("Name:", self)                                           #네임이라는 변수에 큐라벨에 Name이라고 적혀있기        
        name_label.move(10, 50)                                                      #이 라벨의 위치 10, 50 

        # QLineEdit 생성 및 설정  
        self.name_edit = QLineEdit(self)                                              #네임 에딧이라는 변수 설정 : 입력창 가져오기 
        self.name_edit.resize(210, 24)                                                #입력창 사이즈 210, 24
        self.name_edit.move(80, 47)                                                   #80,47위치에 지정  
        self.name_edit.setStyleSheet(                                                 #입력창의 스타일 정하기      
            "background-color: yellow; color: rgb(50, 150, 250);"                     #배경색 노랑, rgb값 대로 지정      
        )
        self.name_edit.setMaxLength(30)                                               #입력가능한 값 최대 30                  
        self.name_edit.setPlaceholderText("Enter your name")                          #미입력시  "Enter your name" 출력        

        # Signal 연결
        self.name_edit.returnPressed.connect(self.on_return_pressed)                  #네임 에딧창에 엔터눌리면 이하 함수 호출       
        self.name_edit.selectionChanged.connect(self.on_selection_changed)            #선택영역이 변경되면 이하 함수 호출          
        self.name_edit.textChanged.connect(self.on_text_changed)                      #글자가 바뀌면 이하 함수 호출         
        self.name_edit.textEdited.connect(self.on_text_edited)                        #문자 수정되면 다음 함수 호출         

        clear_button = QPushButton("Clear", self)                                    #클리어 버튼으로 버튼 하나 가져오기 네임텍 clear  
        clear_button.move(100, 85)                                                   #버튼 위치 100,85  
        clear_button.clicked.connect(self.clear_text)                                #버튼 클릭하면 클리어텍스트 함수 호출             

        ok_button = QPushButton("OK", self)                                          #이하 똑같이 ok로 변경 
        ok_button.move(200, 85)                                                      #버튼 위치 200, 85     
        ok_button.clicked.connect(self.accept_text)                  

    def clear_text(self):                                                          #클리어 텍스트라는 함수 정의 
        """입력 필드를 초기화함."""
        self.name_edit.clear()                                                     #입력창에 있는거 지우기 메서드 활용  

    def accept_text(self):                                                         #accept 함수 정의              
        """입력된 text를 console에 출력하고 창을 닫음."""
        print(f"입력된 이름: {self.name_edit.text()}")                              #입력창에 써진 내용을 cmd에 프린트하기 
        self.close()                                                               #창 닫기  

    def on_return_pressed(self):                                                   #엔터키 눌리면 이 문자 출력    
        print("[returnPressed] Enter 키가 눌렸습니다.")
            
    def on_selection_changed(self):                                                #드레그 범위 변경되면 이 문자 출력 
        print("[selectionChanged] 선택 범위가 변경됐습니다.")  

    def on_text_changed(self, text: str):                                        #이하 동일 변경내용 사용자가 변경하던, 코드로 변경하던 모두 출력 
        print(f"[textChanged] '{text}'")

    def on_text_edited(self, text: str):                                         #이하 동일 사용자가 키보드로 입력 시만  
        print(f"[textEdited] '{text}'")


if __name__ == '__main__':                                                       #여기서만 실행할거고 메모리안남게 끄세요 
    app = QApplication(sys.argv)
    wnd = MW()
    sys.exit(app.exec())
