# labels.py
import sys
import os

try:
    from PySide6.QtWidgets import QApplication, QWidget, QLabel
    from PySide6.QtGui import QFont, QPixmap
    from PySide6.QtCore import Qt
    qt_modules = 'PySide6'                                                #qt모듈을 파이사이드6를 넣어서 나중에 f스트링에 사용 가능하게끔 설정  
except ImportError:
    try:
        from PyQt6.QtWidgets import QApplication, QWidget, QLabel
        from PyQt6.QtGui import QFont, QPixmap
        from PyQt6.QtCore import Qt
        qt_modules = 'PyQt6'
    except ImportError:
        print("PySide6 또는 PyQt6가 설치되어 있지 않습니다.")
        sys.exit(1)

print(f"Using {qt_modules} binding.")


class MW(QWidget):

    def __init__(self):
        super().__init__()
        self.init_ui()                                                                                      #여기init은 initialize를 뜻한다. 

    def init_ui(self):                                                                                      #인잇에 대한 정의를 알려주겠다.                       
        self.setGeometry(100, 100, 250, 200)  # 위치 (100, 100), 크기 250x200                               #모니터 100,100위치에서 위젯크기 250,200        
        self.setFixedSize(250, 200)            # 창 크기 고정 - absolute positioning 사용 시 권장            #고정크기 250,200 건드리지 마시오 
        self.setWindowTitle('QLabel Example')
        self.setup_main_wnd()                                
        self.show()

    def setup_main_wnd(self):
        # text label 생성
        # 아래 한 줄로도 동일하게 생성 가능
        # hello_label = QLabel('Hello, World and Qt!', self)
        hello_label = QLabel(self)                                                #변수를 hello_label로 지정, 큐라벨을 가져와서 사용할 것.
        hello_label.setText('Hello, World and Qt!')                               #헬로라벨이라는 거는 글씨가  'hello, world and qt!'                     
        hello_label.setFont(QFont('Arial', 15))                                   #폰트는 arial, 15폰트 사이즈              
        hello_label.move(10, 10)                                                  #10,10 위치에서 쓰기 시작                   

        # 아래 두 줄을 주석 해제하여 동작 확인 가능
        # hello_label.setAlignment(Qt.AlignmentFlag.AlignCenter)                  #중앙 정렬                               
        # hello_label.setStyleSheet("background-color: yellow")                   #배경색은 노랑 

        # image label 생성
        # 스크립트 파일 위치를 기준으로 image 경로를 계산함
        path_py_file = os.path.dirname(os.path.realpath(__file__))                #변수지성= 폴더까지 경로, 사진까지 경로 두개 합쳐서 path_py_file이라 하자 (경로)        
        img_path = os.path.join(path_py_file, 'img/world.png')

        if os.path.exists(img_path):                                              # 이 이미지 경로가 존재한다면 실행   
            world_label = QLabel(self)                                            #변수지성=큐라벨 가져와             
            pixmap = QPixmap(img_path)                                            #변수지성= 이미지 가져와서 큐픽스맵으로 가용가능하게끔 준비단계                            
            # scaled()는 새로운 QPixmap을 반환함 - in-place 변환이 아님
            pixmap = pixmap.scaled(200, 200, Qt.AspectRatioMode.KeepAspectRatio)  #픽스맵 사이즈 설정= 200,200사이즈를 쓰는데, 원래 사진 비율은 유지하게 한쪽만 200으로 설정하자 더 긴쪽이 200   
            world_label.setPixmap(pixmap)                                         #이제 사진 붙여보자                        
            world_label.move(25, 40)                                              #위젯 내부 25,40 위치에 넣어두겠다   
        else:
            print(f'Image not found: {img_path}')                                 #이 경로가 존재하지 않는다면 이미지가 존재하지 않습니다.    


if __name__ == '__main__':                                                        #여기서만 실행하세요 종료시는 메모리까지 끄세요 
    app = QApplication(sys.argv)
    wnd = MW()
    sys.exit(app.exec())
