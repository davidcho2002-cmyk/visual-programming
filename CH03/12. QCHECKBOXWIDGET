import sys

try:
    from PySide6.QtWidgets import (
        QApplication, QWidget, QLabel,
        QVBoxLayout, QCheckBox, QButtonGroup,
    )
    from PySide6.QtCore import Qt
    qt_modules = 'PySide6'
except ImportError:
    try:
        from PyQt6.QtWidgets import (
            QApplication, QWidget, QLabel,
            QVBoxLayout, QCheckBox, QButtonGroup,
        )
        from PyQt6.QtCore import Qt
        qt_modules = 'PyQt6'
    except ImportError:
        print("PySide6 또는 PyQt6가 설치되어 있지 않습니다.")                      #실행 안되면 오류코드 
        sys.exit(1)

print(f"Using {qt_modules} binding.")


class MW(QWidget):

    def __init__(self):
        super().__init__()
        self.setWindowTitle("Ex: QCheckBox with Exclusive Toggle")
        self.resize(400, 250)
        self.init_ui()
        self.show()                                                                #400,250 위젯 만들기 보여줘라

    def init_ui(self):
        lm = QVBoxLayout()
        self.setLayout(lm)                                                         #수직으로 배치하는데 게시판에 붙이고 시작하기 

        lm.addWidget(QLabel('What is most important?'))                            #다음 행에 'What is most important?' 적어두기                   

        # QCheckBox 3개 생성 및 layout에 추가
        checkbox_texts = ['1. faith', '2. hope', '3. love']                        #리스트 지정 1. faith', '2. hope', '3. love
        self.checkboxes = [QCheckBox(text) for text in checkbox_texts]             #QCHECKBOX라는 박스를 세개 만들고, 그 위에 1, 2, 3, 글자 올리기/ 리스트 안의 반복문 사용            
        for cb in self.checkboxes:                                                 
            lm.addWidget(cb)                                                       #체크박스 네임텍까지 반복해서 행으로 배치   

        # 선택 결과 표시용 label
        self.dp_label = QLabel("")                                                 #공백 라벨 하나 생성       
        lm.addWidget(self.dp_label)                                                #다음 행에 배치   

        # QButtonGroup으로 그룹화 → exclusive 모드로 시작
        self.bg = QButtonGroup(self)                                               #이거에 큐버튼 가져올게    
        for cb in self.checkboxes:
            self.bg.addButton(cb)
        self.bg.setExclusive(True)                                                 #하나만 선택 기능 켜기  
        self.bg.buttonClicked.connect(self.on_checkbox_clicked)                    #함수 호출     

        # exclusive 모드 전환용 check box                                                
        # exclusive=True → 복수 선택 불가이므로, 초기 체크 상태는 False
        self.cb_toggle_exclusive = QCheckBox("Check it for multiple selection.")   #변수지정 체크박스 하나 만들기  
        self.cb_toggle_exclusive.setChecked(not self.bg.exclusive())               #시비토글 배타 체크되면 괄호 안 내용 실행/ self.bg.exclusive()  exclusive: 단일선택인지(ture) 다중선택인지(false) 확인하는 매서드. /처음 아래 다중선택 체크칸에 대해 표시없는 상태로 시작하겠습니다.           
        self.cb_toggle_exclusive.toggled.connect(self.on_toggle_exclusive)         #변수에 대해 / 이 체크박스의 체크상태가 바뀌면 이하 함수 호출 /connect 괄호 안의 함수에 대해 연결하겠다 
        lm.addWidget(self.cb_toggle_exclusive)                                     #다음 행에 배치  

    def on_checkbox_clicked(self, button):                                         #함수 정의   
        """그룹 내 check box 클릭 시 호출됨.
        클릭된 button instance가 인자로 전달됨.                                     #클릭한거 텍스트 동기화    
        """
        self.dp_label.setText(button.text())

    def on_toggle_exclusive(self, state: bool):                                   #함수 정의            
        """exclusive 모드 on/off 전환 처리.                                        #state : 체크가 되어있는지 안되어있는지 qt에 자동으로 전달     
        전환 전에 모든 check box를 unchecked 상태로 초기화함.
        """
        print(f"multiple selection mode: {state}")                               #CMD에 상태 출력 트루퍼스로                
        self.reset_checkboxes(False)                                             #체크가 선택/해제 시마다 위에 그룹박스 체크란을 초기화 false 선택 해제로 만들어라     
        self.bg.setExclusive(not state)                                          #버튼은 ture>선택됨/false>선택 해제 --- setExclusive() true>단일선택/false>다중선택 :::버튼 선택시 다중선택되게, 해재시 단일 선택되게 현재 서로 true false가 엇갈린 상태라서 not으로 우리가 원하는 상태로 적용           

    def reset_checkboxes(self, state: bool):                                     #모든 체크박스 상태 다같이 맞춰주기 / 위에서 state를 false로 지정, 기본값이 해제상태          
        """모든 check box를 주어진 상태(state)로 설정함.

        exclusive 모드에서는 Qt가 "항상 하나는 checked 상태를 유지"하도록 강제함.
        따라서 현재 checked된 버튼에 setChecked(False)를 호출해도 Qt가 이를 무시함.
        결과적으로 exclusive 모드가 활성화된 상태에서는 모든 버튼을 unchecked로 만들 수 없음.
        이를 우회하기 위해 setExclusive(False)로 잠시 해제 후 초기화하고 원래 상태로 복원함.

        세 방식 모두 for문을 사용함. 차이는 어떤 컨테이너를 순회하느냐에 있음.

        approach 01 — self.checkboxes 순회, toggle() 이용:
            현재 checked 상태를 확인 후 반전시키는 방식.
            for cb in self.checkboxes:
                if cb.isChecked(): cb.toggle()

        approach 02 — self.checkboxes 순회, setChecked() 이용:
            목표 상태를 직접 지정하는 방식.
            for cb in self.checkboxes:
                cb.setChecked(state)

        approach 03 — bg.buttons() 순회 (현재 사용):
            QButtonGroup에서 직접 버튼 목록을 가져오므로
            self.checkboxes 같은 별도 attribute를 유지하지 않아도 됨.
        """
        old_exclusive = self.bg.exclusive()                                    #올드 익스클루시브= 트루 퍼스로 받고, 단일선택인지 아닌지 여부를 올드 익스클루시브에 연동  
        self.bg.setExclusive(False)                                            #단일선택을 꺼야 체크 해제가 되기에 단일선택 끄기       

        for cb in self.bg.buttons():   # approach 03                           #체크박스 1,2,3,반복(FOR문으로)          
            cb.setChecked(state)                                               #체크박스 모두 체크 해제         

        self.bg.setExclusive(old_exclusive)                                    #올드 익스클루시브에 상위에 있던 상태 저장 약식으로 하고 , SETEXCLUSIVE에서 무조건 퍼스로 바꿔서 체크 해제 시킬거야, 다시 상위에 있던 상태 불러올거야    
        print("--------------")                                                #CMD에서 ---------출력       


if __name__ == "__main__":                                                      #종료 
    app = QApplication(sys.argv)
    main_wnd = MW()
    sys.exit(app.exec())
