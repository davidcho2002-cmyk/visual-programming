            self.lbl_img_status.setText(os.path.basename(file_path))                    #긴 주소 말고 파일 이름만 가져오기 

    # [AI 기능] Gemini 2.5 Flash 모델 연동 비전 분석
    def analyze_image_with_gemini(self):
        if not HAS_GEMINI:                                              #제미나이 제대로 깔려 있어? 아니면 나와 
            QMessageBox.critical(self, "라이브러리 누락", "google-genai 라이브러리가 설치되지 않았습니다.\npip install google-genai 를 실행하세요.")
            return
        
        if not self.selected_image_path:                                #이미지 경로 제대로 잡혀있어? 아니면 나와 
            QMessageBox.warning(self, "알림", "먼저 분석할 이미지 파일을 선택해 주세요.")
            return

        if not self.ai_client:                                          #API키 제대로 잡혀있어? 아니면 나와 
            QMessageBox.critical(self, "인증 에러", "Gemini API 키가 설정되지 않았거나 클라이언트 생성에 실패했습니다.\n환경변수(GEMINI_API_KEY)를 확인하세요.")
            return

        self.btn_run_ai.setText("⏳ AI 분석 중... 잠시만 기다려주세요")             #분석중일때 AII분석중, 잠시만 기다려주세요 하고, 버튼 안눌리게 변경 
        self.btn_run_ai.setEnabled(False)
        QApplication.processEvents() # UI가 멈추지 않도록 강제 리프레시             #연산 전에 화면 강제로 새로고침해 멈춤 현상 방지 

        try:
            # 1. 파일 데이터 로드 및 미디어타입 매핑
            with open(self.selected_image_path, "rb") as f:                     #사진 바이너리로 가져오기 
                image_bytes = f.read()
            
            ext = os.path.splitext(self.selected_image_path)[-1].lower()        #확장자 추출 후 소문자 변환 
            mime_type = "image/jpeg" if ext in [".jpg", ".jpeg"] else f"image/{ext[1:]}"    #제미나이가 인식할 이미지 종류 라벨 설정 
            
            image_part = types.Part.from_bytes(data=image_bytes, mime_type=mime_type)       # 바이트 데이터와 라벨을 묶어 AI 전용 전송 객체로 최종 조립

            # 2. 현재 모드에 맞춘 구조화된 Prompt 작성 (Structured Outputs 유도)
            prompt = f"""
            너는 이미지에서 데이터를 추출하여 정해진 규칙대로 응답하는 데이터 추출 AI 시스템이다.
            제공된 이미지(영수증, 물품 사진, 차량 사진 등)를 분석하여 현재 시스템 모드인 [{self.current_mode}] 관리에 적합한 정보를 추출해라.

            출력 양식은 반드시 아래의 형식을 철저히 지키고 다른 설명이나 텍스트는 절대 포함하지 마라.
            날짜: YYYY-MM-DD 형식 (알 수 없으면 오늘 날짜인 {datetime.now().strftime('%Y-%m-%d')} 사용)
            내용: 추출한 항목명 또는 차량번호 또는 품목이름 (간결하게 15자 이내)
            수치: 콤마나 단위가 없는 순수 정수 혹은 실수 숫자 (예: 15000)

            예시 출력:
            날짜: 2026-05-18
            내용: 아메리카노
            수치: 4500
            """

            # 3. Gemini 2.5 Flash 모델에 멀티모달 요청 생성
            response = self.ai_client.models.generate_content(                      
                model='gemini-2.5-flash',                                   #구글 이미지 인식 엔진 지정 
                contents=[image_part, prompt]                               #분석할 사진, 미션 명령어 묶어서 전송 
            )                                                               # AI가 분석해서 뱉은 결과(return)를 response 변수에 저장
            
            result_text = response.text.strip()                             # AI 답변에서 순수 글자만 추출(.text)하고 앞뒤 불필요한 공백을 제거(.strip)하여 변수에 저장
            
            # 4. 결과 파싱 작업
            parsed_data = {}                                            # 파싱한 데이터를 저장할 빈 딕셔너리 생성
            for line in result_text.split('\n'):                        # AI 답변을 줄바꿈(\n) 기준으로 쪼개어 한 줄씩 분석
                if ':' in line:                                         # 해당 줄에 콜론(:) 구분자가 포함되어 있다면
                    key, val = line.split(':', 1)                       # 콜론을 기준으로 왼쪽(Key)과 오른쪽(Value) 딱 반으로 쪼갬
                    parsed_data[key.strip()] = val.strip()               # 앞뒤 공백을 청소(.strip)한 뒤 딕셔너리에 최종 저장

            # 5. UI 입력창에 값 세팅
            if "날짜" in parsed_data: self.edit1.setText(parsed_data["날짜"])           #보관함에 날짜 데이터 있으면 첫번째 입력창에 자동 입력 
            if "내용" in parsed_data: self.edit2.setText(parsed_data["내용"])           #내용 있으면 두번째 입력창 입력 
            if "수치" in parsed_data: self.edit3.setText(parsed_data["수치"])           #수치 있으면 두번째 입력창 입력 

            #성공 알림 및 추출 데이터 검수용 팝업창 표시 
            QMessageBox.information(self, "완료", f"AI 분석 완료!\n추출된 데이터를 확인하고 기록 버튼을 누르세요.\n\n[추출 결과]\n{result_text}")
                            
            # 다음 분석을 위해 상태 초기화
            self.selected_image_path = ""
            self.lbl_img_status.setText("선택된 사진 없음")

        except Exception as e:                                                          #에러 처리 
            QMessageBox.critical(self, "AI 분석 오류", f"Gemini API 호출 중 문제가 발생했습니다:\n{str(e)}")        # 에러 발생 시 프로그램 튕김을 방지하고 빨간색 에러 팝업창으로 원인 표시
        finally:                                                                       # 성공하든 에러가 나든 '무조건' 마지막에 실행되는 구역
            self.btn_run_ai.setText("⚡ AI 이미지 분석 및 자동 입력")                   #로딩중인걸 초기화 원래대로 리셋 
            self.btn_run_ai.setEnabled(True)                                           #체크 불가능한 버튼을 체크 가능하도록 변경 

    def save_data(self):
        v1, v2, v3 = self.edit1.text(), self.edit2.text(), self.edit3.text() # 입력창 3형제의 텍스트(날짜, 내용, 수치)를 각각 읽어옴
        if v1 and v2 and v3:                                            # 세 칸 모두 빈틈없이 채워져 있다면 진행
            try:
                val = float(v3)                                         # 그래프 연산을 위해 문자열 수치를 숫자(실수)형으로 변환 시도
                self.data[self.current_mode].append((v2, val))          # 현재 모드(용돈/창고) 데이터 리스트에 (내용, 숫자) 추가
                self.update_plot()                                      # 데이터가 바뀌었으므로 Matplotlib 그래프 실시간 갱신
                self.edit2.clear(); self.edit3.clear()                  # 다음 입력을 위해 내용창과 수치창을 깨끗이 비우기
            except ValueError:                                          # 만약 수치 칸에 숫자가 아닌 문자가 들어와 에러가 나면
                QMessageBox.warning(self, "에러", "수치는 숫자만 입력하세요.") # 경고창을 띄우고 프로그램 튕김 방지
        else:
            QMessageBox.warning(self, "알림", "모든 칸을 채워주세요.")         # 빈 칸이 하나라도 있으면 경고 표시

    def update_plot(self):
        self.ax.clear()                                                 # 새로운 그래프를 그리기 위해 기존 칠판을 깨끗이 지움
        current_list = self.data[self.current_mode]                     # 현재 모드(용돈/창고)에 누적된 데이터 리스트 가져오기
        
        if not current_list:                                            # 만약 저장된 데이터가 하나도 없다면 (초기 상태)
            self.ax.set_title(f"{self.current_mode} 현황 (데이터 없음)")     # 차트 제목에 데이터 없음 표시
            if self.current_mode == "용돈":
                self.ax.set_ylim(0, 20000)                              # Y축 범위 기본 세팅 (0 ~ 20,000원)
                ticks = range(0, 21000, 2000)                           # 2,000 단위로 눈금 생성
                self.ax.set_yticks(ticks)
                self.ax.set_yticklabels([f"{x:,}" for x in ticks])       # 눈금에 천 단위 콤마(,) 포맷팅 적용
            self.ax.grid(True, alpha=0.2)                               # 은은한 투명도(0.2)로 배경 가이드 격자선 그리기
            self.figure.tight_layout()                                  # 여백 자동 조절
            self.canvas.draw()                                          # 빈 가이드 화면을 캔버스에 최종 반영
            return                                                      # 🚨 데이터가 없으므로 하단 그리기 로직을 패스하고 즉시 함수 탈출
            
        names = [x[0] for x in current_list]                            # 그래프 X축에 쓸 '내용(이름)'만 리스트로 쏙 솎아내기
        values = [x[1] for x in current_list]                           # 그래프 막대 높이가 될 '수치(숫자)'만 리스트로 쏙 솎아내기

        if self.current_mode == "용돈":
            # 1. 지출 지점에 세련된 딥블루 색상의 큰 점(Size 120) 찍기 (zorder=3으로 맨 위에 표시)
            self.ax.scatter(range(len(values)), values, color='#2980b9', s=120, zorder=3)
            # 2. 점들을 잇는 은은한(투명도 0.5) 하늘색 점선(--) 그래프 그리기
            self.ax.plot(range(len(values)), values, color='#3498db', linestyle='--', alpha=0.5)
            
            # 3. Y축 범위 설정 및 천 단위 콤마(,) 눈금 표시 (0 ~ 20,000원까지 2,000 단위)
            self.ax.set_title("용돈 지출 현황 (Max 20,000)")
            self.ax.set_ylim(0, 20000)
            ticks = range(0, 21000, 2000)
            self.ax.set_yticks(ticks)
            self.ax.set_yticklabels([f"{x:,}" for x in ticks])
            
            # 4. X축에 지출처(상호명)를 표시하고, 글자 겹침 방지를 위해 15도 회전 세팅
            self.ax.set_xticks(range(len(names)))
            self.ax.set_xticklabels(names, rotation=15)

        elif self.current_mode == "창고":                                # 현재 모드가 '창고' 모드라면 진행
            # 1. 물품명(names)과 재고수량(values)으로 세련된 오렌지색(#e67e22) 막대그래프 그리기 (두께 0.6)
            bars = self.ax.bar(names, values, color='#e67e22', width=0.6)
            
            # 2. 막대 기둥 바로 위에 실제 재고 수량을 소수점 없는 정수 형태('%.0f')로 딱 박아주기
            self.ax.bar_label(bars, fmt='%.0f')
            
            # 3. 차트 제목을 변경하고, X축 물품 이름들이 서로 겹치지 않게 15도 비스듬히 회전 세팅
            self.ax.set_title("창고 재고 현황")
            self.ax.set_xticklabels(names, rotation=15)
        
        elif self.current_mode == "차량":                                # 현재 모드가 '차량' 모드라면 진행
            # 1. 신뢰감을 주는 초록색(#27ae60) 실선과 큼직한 동그라미 점(Size 8)으로 차량 로그 그래프 그리기
            self.ax.plot(names, values, marker='o', color='#27ae60', linewidth=2, markersize=8)
            self.ax.set_title("차량 입출 기록")
            self.ax.set_xticklabels(names, rotation=15)

        # [최종 공통 마감 구역] 모든 모드가 그리기 완료 후 거쳐가는 구역
        self.ax.grid(True, alpha=0.3)                                   # 투명도 0.3의 은은한 가이드 배경 격자선 그리기
        self.figure.tight_layout()                                      # X축 글자 회전 등으로 인한 여백 잘림 현상 자동 방지
        self.canvas.draw()                                              # 메모리에 완성된 그래프를 유저 화면(Canvas)에 실시간 최종 송출

    def export_to_excel(self):
        if not self.data[self.current_mode]:                            # 현재 모드에 누적된 데이터가 하나도 없다면
            QMessageBox.warning(self, "알림", "내보낼 데이터가 없습니다.")     # 경고창 표시 후
            return                                                      # 🚨 파일 저장 로직을 실행하지 않고 즉시 함수 탈출
        try:
            # 1. 누적 데이터 리스트를 판다스 데이터프레임(엑셀 표 형태)으로 변환
            df = pd.DataFrame(self.data[self.current_mode], columns=['항목/내용', '수치'])
            
            # 2. 유저 시스템의 바탕화면(Desktop) 경로를 자동으로 계산하여 안전한 파일 주소 생성
            desktop = os.path.join(os.path.expanduser("~"), "Desktop")
            file_path = os.path.join(desktop, f"David_{self.current_mode}_데이터.xlsx")
            
            # 3. 엑셀 파일로 저장 (좌측 인덱스 번호 열은 제외하고 저장)
            df.to_excel(file_path, index=False)
            QMessageBox.information(self, "성공", f"엑셀 파일이 바탕화면에 저장되었습니다!")
            
            # 4. 저장 완료 후 유저가 바로 확인할 수 있도록 바탕화면 폴더 탐색기를 자동으로 열어줌
            os.startfile(desktop)
        except Exception as e:                                          # 파일이 열려있거나 권한 문제 등으로 에러 발생 시
            QMessageBox.critical(self, "에러", f"엑셀 저장 중 오류: {str(e)}") # 프로그램 튕김을 막고 에러 메시지 팝업 출력

