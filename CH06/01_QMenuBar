import sys, os
from PyQt6.QtWidgets import QApplication, QMainWindow, QLabel
from PyQt6.QtGui import QAction, QIcon
from PyQt6.QtCore import Qt

class MW (QMainWindow):
  def __init__(self):
    super().__init__()
    self.init_ui()
  def init_ui(self):
    """ application의 gui를 초기화하는 메서드"""
    self.fstr = os.path.dirname(                          #경로 편집
      os.path.abspath(__file__)                             #절대경로도 사용해요 
    )
    self.setMinimumSize(600,600)
    self.setWindowTitle("Menu bar Ex")
    self.setup_main_wnd()    # main window를 설정하는 메서드 (풀소스코드 참고)
    self.create_actions()        # menu bar에서 수행될 command들에 해당하는 action생성.
    self.create_menu()          # menu bar 생성. 앞서 생성된 action들을 활용.
    self.show()

  def create_actions (self):                            #명령 하나를 나타내는 객체 
    self.quit_act = QAction("Quit")                     #quit이라는 변수에다가 종료를 마음대로 쓰게 
    self.quit_act.setShortcut("Ctrl+X")                 #잘라내기도 단축키로 사용하겠습니다
    self.quit_act.setIcon(QIcon(f"{self.fstr}/img/exit.png"))           #이 변수에 대해 아이콘 지정, 내가 원하는 사진에 대해 가져오기 
    # self.quit_act.setIcon(QIcon("img/exit.png"),"Quit") #action의 icon과 이름을 한번에 지정.
    self.quit_act.triggered.connect(self.close)                 #실행됐을 때 발생하는 신호, 닫는 액션중에 하나로 추정 

  def create_menu(self):                                #메뉴 설정 
    """어플리케이션의 menu bar를 만드는 method."""
    mb = self.menuBar()                         # main window의 menu bar를 추상화한 instance.   #명박이 지정 
    menu_item = mb.addMenu("test")    # test 라는 이름의 menu item을 추가.
    menu_item.addAction(self.quit_act) # test 메뉴아이템에 아까 만든 QAction instance추가.      #테스트 버튼을 누르면 닫힌다 
    mb.setNativeMenuBar(False) # for macOS          #메뉴바 운영체재 기본 방식 대신에 우리가 만든 메뉴바가 보이게 한다 /맥에서 타이틀바가 아니라 최상단에 나오는 것을 방지하기 위해 이렇게 설정한다 

  def setup_main_wnd(self):                 #도장꽝
    label = QLabel('test')
    label.setAlignment(Qt.AlignmentFlag.AlignCenter)
    self.setCentralWidget(label)

if __name__ == "__main__":                  #종료 
  app = QApplication(sys.argv)
  wnd = MW()
  sys.exit(app.exec())
