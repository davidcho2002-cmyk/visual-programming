import sys, os                              #기본 세팅입니다.
from datetime import datetime

from PySide6.QtWidgets import (
    QApplication, 
    QMainWindow,
    QStatusBar,
    QLabel,
    QProgressBar,
    QPushButton,
)

from PySide6.QtCore import QTimer                       


class MW(QMainWindow):  # QMainWindow 기반의 메인 윈도우 클래스 정의                #메인 윈도우 기본설정 

    def __init__(self):
        super(MW, self).__init__()  # 부모 클래스 생성자 호출

        # 상태바 객체를 생성 (QMainWindow의 내장 메서드 이용)
        self.status_bar = self.statusBar()                                  #스테이터스바라는 메서드 가져오고 이걸 변수로 만들거야
        # self.setStatusBar(self.status_bar)  # 생략 가능. 이미 기본으로 설정됨.

        # -------------------- 시계 표시 설정 --------------------
        # 타이머 생성: 1초마다 현재 시간을 상태바에 표시
        self.timer0 = QTimer(self)                              #도구 가져와서 변수입력 
        self.timer0.timeout.connect(self.update_clk)            #후술할 함수에 시간오버될 때 받는 신호 받고 이 변수랑 연결시키겠다 
        self.timer0.start(1000)  # 1000ms = 1초 주기             #1초에 한번씩 타임 아웃 시그널이 나오게 1초마다 이 위의 함수를 가져오기        

        # 상태바의 우측 고정 영역에 시간 라벨 추가 (영구 위젯)
        self.clk_label = QLabel()                               #라벨 가져오기 
        self.status_bar.addPermanentWidget(self.clk_label)      #고정된 위젯 하나 만들기 여기 안에 clk label함수 집어넣을것    
                                                                #시계는 영구적으로 보이게끔 
        # -------------------- 진행률 표시 설정 --------------------
        # 상태바에 표시될 프로그레스 바 (임시 위젯)
        self.progress_bar = QProgressBar(self, minimum=0, maximum=100)      #직진바 가져오기 도구 가져와서 변수 입력 0~100까지 진행도 

        # 상태바에 위젯을 추가할 때 두 번째 인자는 "stretch factor"를 의미
        # 이 값이 클수록 해당 위젯이 더 많은 가로 공간을 차지하게 됨
        # 여기서 1은 가변 크기를 허용함을 의미하며, 다른 위젯과 공간을 유동적으로 나눔
        self.status_bar.addWidget(self.progress_bar, 1)  # 가변 폭 설정        #공간 분배 비율 1정도로, 유동적으로 이동 가능하게 이 바가 

        # -------------------- 중앙 버튼 --------------------
        # 중앙에 위치할 버튼 생성 및 클릭 이벤트 연결
        self.btn = QPushButton('Start Progress!')                                   #버튼 만들기 
        self.btn.clicked.connect(self.start_progress)
        self.setCentralWidget(self.btn)  # QMainWindow의 중앙 위젯 설정

        # -------------------- 프로그레스 타이머 --------------------
        # 100ms 간격으로 프로그레스 바 업데이트
        self.timer1 = QTimer(self)                                          #새로운 변수 지정 
        self.timer1.timeout.connect(self.update_progress)                    #스타트 프로그래스, 업데이트 프로그래스 두 함수를 가지고 아래에서 설명하는대로 움직이자        
        self.progress_value = 0  # 현재 진행률 초기값

        self.show()  # 윈도우 표시

    def start_progress(self):                               #이거 설명할거야 
        # 버튼 클릭 시 프로그레스바 초기화 및 진행 시작
        self.progress_value = 0                             #0으로 설정하고  
        self.progress_bar.reset()                           #바도 리셋을 시킬게요 
        self.progress_bar.setValue(self.progress_value)     #값 설정, 프로그래스 밸류 변수대로 
        self.timer1.start(100)  # 0.1초 간격으로 update_progress 호출       
        self.status_bar.showMessage('Progress started...', 2000)  # 2초간 메시지 표시

    def update_clk(self):                                       #현재시간 보여주기 
        # 현재 시간 문자열을 상태바의 영구 위젯에 표시
        now = datetime.now()
        now_str = now.strftime('%H:%M:%S')  # '시:분:초' 형식 문자열
        self.clk_label.setText(now_str)             #현재시간 동기화?

    def update_progress(self):                      #이 함수 설정 
        # 타이머에 의해 호출되며 프로그레스 값을 증가시킴
        if self.progress_value < 100:               #100 미만인 경우 
            self.progress_value += 1                #숫자 1씩 오라가기 
            self.progress_bar.setValue(self.progress_value)     #프로그래스 바에서 변하는거를 위의 변수에 맞춰 계속 움직이게 
        else:
            self.timer1.stop()  # 100에 도달 시 타이머 정지
            self.status_bar.showMessage('Progress completed...', 2000)  # 완료 메시지

# -------------------- 앱 실행 -------------------- 
if __name__ == '__main__':                                                              #종료 
    app = QApplication(sys.argv)  # QApplication 인스턴스 생성
    wnd = MW()  # 메인 윈도우 생성 및 표시
    sys.exit(app.exec())  # 이벤트 루프 실행 및 정상 종료 처리
