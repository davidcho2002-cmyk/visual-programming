import sys, os                  #시작하자 

from PyQt6.QtWidgets import (QApplication, QMainWindow,
                             QToolBar, QLabel,QStatusBar)
from PyQt6.QtCore import Qt, QSize
from PyQt6.QtGui import QAction,QIcon

class MW (QMainWindow):         #위젯 설정 

    def __init__(self):         #기본값 설정 
        super().__init__()
        self.init_ui()

    def init_ui(self):
        self.fpath = os.path.dirname(           #폴더이름 가져오기 
            os.path.abspath(__file__)
        )
        self.setFixedSize(600,600)          #위젯 크기 설정 
        self.setWindowTitle("ds status bar Ex")
        self.setup_main_wnd()
        self.create_actions()                   #이하 말하는 함수들 후술 할 것 
        self.create_tool_bar()
        self.create_menu()
        self.setStatusBar(QStatusBar()) #최초 호출시 status bar 추가됨.
        self.show()

    def setup_main_wnd(self):           #메인윈도우 함수 설정 
        self.label = QLabel("QStatusBar Example")       #큐 라벨에 큐스테이터스바 이그엠플 
        self.label.setAlignment(                        #라벨 배치 
            Qt.AlignmentFlag.AlignCenter                
        )
        self.setCentralWidget(self.label)

    def create_actions(self):                       #함수 설명 
        self.open_act = QAction(
            QIcon(f"{self.fpath}/img/open_file.png"),       #qaction도구 사용, 아이콘 올때, 오픈 역할 가진 액션함수 하나 만들기,  
            "Open"
        )
        self.open_act.setShortcut("Ctrl+O")             #단축키 설정 컨 o
        self.open_act.triggered.connect(                #단축키랑, 변수랑 연결 
            self.open_event
        )
        # status bar에 action관련 메시지 출력.
        self.open_act.setStatusTip('Open will display some msg on the central widget.')     #도움말 스테이터스바에 추가 

        self.close_act = QAction(                       #창 닫기 액션    
            QIcon(f"{self.fpath}/img/clear.png"),           
            "Close"
        )
        self.close_act.setShortcut("Ctrl+X")            #컨x사용해서 닫기 
        self.close_act.triggered.connect(
            self.close
        )
        # status bar에 action관련 메시지 출력.
        self.close_act.setStatusTip('Close will quit this program.')    #도움말 설정 

    def create_tool_bar(self):          #함수 설명 
        tool_bar = QToolBar("QToolBar for QStatusBar Ex")       #툴바에다가 이하 내용 작성 
        tool_bar.setIconSize(QSize(30,30))                  #툴바 사이즈 설정 

        tool_bar.addAction(self.open_act)               #오픈하는 액트 하나 만들기 
        tool_bar.addSeparator()                         #구분선 작성 
        tool_bar.addAction(self.close_act)              #클로즈 액트 하나 만들기 

        self.addToolBar(tool_bar)                   #툴바 만들기 

    def create_menu(self):                  #메뉴 만들기 

        mb = self.menuBar()                 #기존 메뉴바에 대해 아무것도 없는거로 일단 지정 
        mb.setNativeMenuBar(False)          #맥에서 오류나는거 설정하기 위해 

        open_menu = mb.addMenu("Open")      #오픈 메뉴 , 바가 나타나게 
        open_menu.addAction(self.open_act)  #오픈 메뉴 안에 메뉴바 열게끔 만들기 

    def open_event(self):                   #함수 설명 
        if self.label.text() != "open clicked ok":      #라벨에 오픈클릭드오케이가 아니라면 
            self.label.setText("open clicked ok")       #이하 문구 실행 
            self.statusBar().showMessage("open clicked") # status bar에 문자열 출력
        else:
            self.label.setText("open clicked ok again")     #오픈클릭드 어게인으로 바꾸겠다 
            self.statusBar().showMessage("open clicked again") #오픈클릭드 어게인 뜨게끔 메시지 방출

if __name__ == "__main__":                  #종료 
    app = QApplication(sys.argv)
    wnd = MW()
    sys.exit(app.exec())
